{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/payment/success",
      "destination": "/index.html"
    },
    {
      "source": "/payment/fail",
      "destination": "/index.html"
    },
    {
      "source": "/payment/cancel",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}